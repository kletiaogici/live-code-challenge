{
  "name": "@greenlab-challenge/api",
  "type": "module",
  "version": "1.0.0",
  "description": "Express.js API server with Kysely",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --exec tsx src/index.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "db:migrate": "tsx db/migrate.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "kysely": "^0.28.10",
    "pg": "^8.13.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.14",
    "@types/express": "^4.17.17",
    "@types/node": "^20.8.0",
    "@types/pg": "^8.11.0",
    "nodemon": "^3.0.2",
    "tsx": "^3.14.0",
    "typescript": "^5.2.2"
  }
}
